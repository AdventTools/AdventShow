// @see - https://www.electron.build/configuration/configuration
{
  "appId": "com.adventtools.adventshow",
  "asar": true,
  "asarUnpack": [
    "**/node_modules/ffmpeg-static/**",
    "**/node_modules/better-sqlite3/**"
  ],
  "productName": "AdventShow",
  "icon": "build/icon.png",
  "directories": {
    "output": "release/${version}",
    "buildResources": "build"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  "extraResources": [
    {
      "from": "public/hymns.db",
      "to": "hymns.db",
      "filter": ["**/*"]
    },
    {
      "from": "scripts/cornilescu.json",
      "to": "cornilescu.json",
      "filter": ["**/*"]
    },
    {
      "from": "electron/certs/adventshow.crt",
      "to": "adventshow.crt",
      "filter": ["**/*"]
    }
  ],
  "afterPack": "./scripts/afterPack.cjs",
  "mac": {
    "icon": "build/icons/mac/icon.icns",
    // SHA1 al certificatului Developer ID din keychain. Înlocuibil — vezi scripts/signing.env
    "identity": "CAFB6F4197186A7AF5EBE17111147ADF58CFD0A7",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "notarize": false,
    "target": [
      "dmg"
    ],
    "artifactName": "AdventShow-Mac-${version}.${ext}"
  },
  "win": {
    "icon": "build/icons/win/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "AdventShow-Setup.${ext}",
    "sign": "./scripts/sign-windows.cjs",
    "signingHashAlgorithms": ["sha256"]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "AdventShow",
    "include": "build/installer.nsh"
  },
  "linux": {
    "icon": "build/icons/png",
    "target": [
      "AppImage"
    ],
    "artifactName": "AdventShow-Linux.${ext}"
  }
}
